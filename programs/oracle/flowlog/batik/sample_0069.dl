ReturnNonvoid_Var(instruction, var) :- _Return(instruction, index, var, method).
LoadInstanceField(base, sig, to, inmethod) :- LoadInstanceField_Base(insn, base), LoadInstanceField_To(insn, to), Instruction_Method(insn, inmethod), FieldInstruction_Signature(insn, sig).
StoreInstanceField(from, base, sig, inmethod) :- StoreInstanceField_From(insn, from), StoreInstanceField_Base(insn, base), FieldInstruction_Signature(insn, sig), Instruction_Method(insn, inmethod).
LoadStaticField(sig, to, inmethod) :- Instruction_Method(insn, inmethod), FieldInstruction_Signature(insn, sig), LoadStaticField_To(insn, to).
StoreStaticField(from, sig, inmethod) :- StoreStaticField_From(insn, from), FieldInstruction_Signature(insn, sig), Instruction_Method(insn, inmethod).
LoadArrayIndex(base, to, inmethod) :- Instruction_Method(insn, inmethod), LoadArrayIndex_To(insn, to), LoadArrayIndex_Base(insn, base).
StoreArrayIndex(from, base, inmethod) :- Instruction_Method(insn, inmethod), StoreArrayIndex_Base(insn, base), StoreArrayIndex_From(insn, from).
AssignCast(type, from, to, inmethod) :- Instruction_Method(insn, inmethod), AssignInstruction_To(insn, to), AssignCast_Type(insn, type), AssignCast_From(insn, from).
AssignLocal(from, to, inmethod) :- AssignInstruction_To(insn, to), Instruction_Method(insn, inmethod), AssignLocal_From(insn, from).
AssignHeapAllocation(heap, to, inmethod) :- Instruction_Method(insn, inmethod), AssignInstruction_To(insn, to), AssignHeapAllocation_Heap(insn, heap).
ReturnVar(var, method) :- Instruction_Method(insn, method), ReturnNonvoid_Var(insn, var).
StaticMethodInvocation(invocation, signature, inmethod) :- isStaticMethodInvocation_Insn(invocation), Instruction_Method(invocation, inmethod), MethodInvocation_Method(invocation, signature).
