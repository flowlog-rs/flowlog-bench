Assign(actual, formal) :- FormalParam(index, method, formal), ActualParam(index, invocation, actual), CallGraphEdge(invocation, method).
Assign(return, local) :- CallGraphEdge(invocation, method), ReturnVar(return, method), AssignReturnValue(invocation, local).
VarPointsTo(heap, var) :- AssignHeapAllocation(heap, var, inMethod), Reachable(inMethod).
VarPointsTo(heap, to) :- Assign(from, to), VarPointsTo(heap, from).
VarPointsTo(heap, to) :- Reachable(inmethod), AssignLocal(from, to, inmethod), VarPointsTo(heap, from).
VarPointsTo(heap, to) :- HeapAllocation_Type(heap, heaptype), VarPointsTo(heap, from), AssignCast(type, from, to, inmethod), Reachable(inmethod), SupertypeOf(type, heaptype).
ArrayIndexPointsTo(baseheap, heap) :- ComponentType(baseheaptype, componenttype), SupertypeOf(componenttype, heaptype), HeapAllocation_Type(heap, heaptype), VarPointsTo(heap, from), StoreArrayIndex(from, base, inmethod), HeapAllocation_Type(baseheap, baseheaptype), Reachable(inmethod), VarPointsTo(baseheap, base).
VarPointsTo(heap, to) :- VarPointsTo(baseheap, base), HeapAllocation_Type(baseheap, baseheaptype), ComponentType(baseheaptype, basecomponenttype), LoadArrayIndex(base, to, inmethod), SupertypeOf(type, basecomponenttype), Var_Type(to, type), Reachable(inmethod), ArrayIndexPointsTo(baseheap, heap).
VarPointsTo(heap, to) :- LoadInstanceField(base, signature, to, inmethod), VarPointsTo(baseheap, base), InstanceFieldPointsTo(heap, signature, baseheap), Reachable(inmethod).
VarPointsTo(heap, to) :- LoadStaticField(fld, to, inmethod), StaticFieldPointsTo(heap, fld), Reachable(inmethod).
VarPointsTo(heap, this) :- VirtualMethodInvocation_SimpleName(invocation, simplename), MethodLookup(simplename, descriptor, heaptype, toMethod), Instruction_Method(invocation, inMethod), VirtualMethodInvocation_Descriptor(invocation, descriptor), HeapAllocation_Type(heap, heaptype), VarPointsTo(heap, base), VirtualMethodInvocation_Base(invocation, base), ThisVar(toMethod, this), Reachable(inMethod).
InstanceFieldPointsTo(heap, fld, baseheap) :- StoreInstanceField(from, base, fld, inmethod), VarPointsTo(heap, from), Reachable(inmethod), VarPointsTo(baseheap, base).
StaticFieldPointsTo(heap, fld) :- Reachable(inmethod), StoreStaticField(from, fld, inmethod), VarPointsTo(heap, from).
Reachable(toMethod) :- VirtualMethodInvocation_Base(invocation, base), VirtualMethodInvocation_Descriptor(invocation, descriptor), MethodLookup(simplename, descriptor, heaptype, toMethod), HeapAllocation_Type(heap, heaptype), Instruction_Method(invocation, inMethod), VirtualMethodInvocation_SimpleName(invocation, simplename), VarPointsTo(heap, base), Reachable(inMethod).
CallGraphEdge(invocation, toMethod) :- Instruction_Method(invocation, inMethod), VirtualMethodInvocation_Base(invocation, base), VirtualMethodInvocation_Descriptor(invocation, descriptor), VirtualMethodInvocation_SimpleName(invocation, simplename), Reachable(inMethod), VarPointsTo(heap, base), HeapAllocation_Type(heap, heaptype), MethodLookup(simplename, descriptor, heaptype, toMethod).
Reachable(tomethod) :- Reachable(inmethod), StaticMethodInvocation(invocation, tomethod, inmethod).
CallGraphEdge(invocation, tomethod) :- Reachable(inmethod), StaticMethodInvocation(invocation, tomethod, inmethod).
Reachable(tomethod) :- Instruction_Method(invocation, inmethod), SpecialMethodInvocation_Base(invocation, base), VarPointsTo(heap, base), MethodInvocation_Method(invocation, tomethod), ThisVar(tomethod, this), Reachable(inmethod).
CallGraphEdge(invocation, tomethod) :- Instruction_Method(invocation, inmethod), SpecialMethodInvocation_Base(invocation, base), Reachable(inmethod), MethodInvocation_Method(invocation, tomethod), ThisVar(tomethod, this), VarPointsTo(heap, base).
VarPointsTo(heap, this) :- SpecialMethodInvocation_Base(invocation, base), VarPointsTo(heap, base), Instruction_Method(invocation, inmethod), Reachable(inmethod), MethodInvocation_Method(invocation, tomethod), ThisVar(tomethod, this).
Reachable(method) :- MainMethodDeclaration(method).
